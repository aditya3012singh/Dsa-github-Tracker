{
  "name": "coding-analytics-platform",
  "version": "1.0.0",
  "description": "Department Coding Analytics Platform",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js & node dist/workers/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "worker": "ts-node src/workers/index.ts",
    "worker:prod": "node dist/workers/index.js",
    "build": "tsc",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "seed": "ts-node src/scripts/seed.ts",
    "parse:students": "ts-node src/scripts/parse-students.ts",
    "merge:data": "ts-node src/scripts/merge-data.ts",
    "seed:all": "ts-node src/scripts/seed_all.ts",
    "seed:all:clear": "ts-node src/scripts/seed_all.ts --clear"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "axios": "^1.6.7",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.4.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "node-cron": "^3.0.3",
    "prom-client": "^15.1.3",
    "uuid": "^14.0.1",
    "winston": "^3.12.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.11.20",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^10.0.0",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
