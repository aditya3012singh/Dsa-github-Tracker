generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id               String    @id @default(uuid())
  name             String
  libraryId        String    @unique
  rollNo           String?
  email            String?   @unique
  branch           String
  year             Int
  section          String?
  leetcodeHandle   String?
  codeforcesHandle String?
  gfgHandle        String?
  codechefHandle   String?
  githubHandle     String?
  password         String
  resetToken       String?   @unique
  resetTokenExpiry DateTime?
  createdAt        DateTime  @default(now())

  // Relations
  codingStats      CodingStats?

  @@index([year])
  @@index([branch])
  @@index([section])
}

model CodingStats {
  id                  String   @id @default(uuid())
  studentId           String   @unique
  student             Student  @relation(fields: [studentId], references: [id])
  leetcodeSolved      Int      @default(0)
  leetcodeEasy        Int      @default(0)
  leetcodeMedium      Int      @default(0)
  leetcodeHard        Int      @default(0)
  codeforcesRating    Int      @default(0)
  codeforcesMaxRating Int      @default(0)
  codechefRating      Int      @default(0)
  gfgSolved           Int      @default(0)
  overallScore        Float    @default(0)
  totalSolved         Int      @default(0)
  updatedAt           DateTime @updatedAt
  codechefSolved      Int      @default(0)
  githubContributions Int      @default(0)
  githubFollowers     Int      @default(0)
  githubFollowing     Int      @default(0)
  githubRepos         Int      @default(0)
  
  @@index([overallScore(sort: Desc)])
  @@index([totalSolved(sort: Desc)])
  @@index([leetcodeSolved(sort: Desc)])
  @@index([codeforcesRating(sort: Desc)])
  @@index([gfgSolved(sort: Desc)])
}

model FetchJob {
  id        String   @id @default(uuid())
  studentId String
  platform  String
  status    String
  lastRun   DateTime @default(now())

  @@unique([studentId, platform])
}

model RankHistory {
  id        String   @id @default(uuid())
  studentId String
  rank      Int
  score     Float
  createdAt DateTime @default(now())

  @@index([studentId])
  @@index([createdAt])
}
