{
  "title": "🗄️ PostgreSQL / Prisma Dashboard",
  "uid": "prisma-dashboard",
  "refresh": "5s",
  "schemaVersion": 38,
  "version": 2,
  "timezone": "browser",
  "editable": true,
  "tags": [
    "prisma",
    "postgres",
    "observability",
    "coding-analytics"
  ],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "model",
        "type": "query",
        "query": "label_values(coding_analytics_prisma_queries_total, model)",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "allValue": ".*"
      },
      {
        "name": "operation",
        "type": "query",
        "query": "label_values(coding_analytics_prisma_queries_total, operation)",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "allValue": ".*"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Queries / sec",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(coding_analytics_prisma_queries_total{model=~\"$model\", operation=~\"$operation\"}[$__rate_interval]))",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" }
    },
    {
      "id": 2,
      "title": "Avg Latency",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "(sum(rate(coding_analytics_prisma_query_duration_seconds_sum{model=~\"$model\", operation=~\"$operation\"}[$__rate_interval])) / clamp_min(sum(rate(coding_analytics_prisma_query_duration_seconds_count{model=~\"$model\", operation=~\"$operation\"}[$__rate_interval])), 1)) * 1000",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" }
    },
    {
      "id": 3,
      "title": "Slow Queries",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(coding_analytics_prisma_slow_queries_total{model=~\"$model\", operation=~\"$operation\"}[$__rate_interval]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" }
    },
    {
      "id": 4,
      "title": "Success Rate",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "100 - (100 * sum(rate(coding_analytics_prisma_errors_total{model=~\"$model\", operation=~\"$operation\"}[$__rate_interval])) / clamp_min(sum(rate(coding_analytics_prisma_queries_total{model=~\"$model\", operation=~\"$operation\"}[$__rate_interval])), 1))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 95 },
              { "color": "green", "value": 99 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" }
    },
    {
      "id": 5,
      "title": "Query Throughput",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "sum(rate(coding_analytics_prisma_queries_total{model=~\"$model\", operation=~\"$operation\"}[$__rate_interval]))",
          "refId": "A",
          "legendFormat": "Queries/sec"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 12,
      "title": "Throughput by Model",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 6 },
      "targets": [
        {
          "expr": "sum by(model)(rate(coding_analytics_prisma_queries_total{model=~\"$model\", operation=~\"$operation\"}[$__rate_interval]))",
          "refId": "A",
          "legendFormat": "{{model}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 13,
      "title": "Throughput by Operation",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "targets": [
        {
          "expr": "sum by(operation)(rate(coding_analytics_prisma_queries_total{model=~\"$model\", operation=~\"$operation\"}[$__rate_interval]))",
          "refId": "A",
          "legendFormat": "{{operation}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 14,
      "title": "Latency Percentiles",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(coding_analytics_prisma_query_duration_seconds_bucket{model=~\"$model\", operation=~\"$operation\"}[$__rate_interval])) by(le)) * 1000",
          "refId": "P50",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(coding_analytics_prisma_query_duration_seconds_bucket{model=~\"$model\", operation=~\"$operation\"}[$__rate_interval])) by(le)) * 1000",
          "refId": "P95",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(coding_analytics_prisma_query_duration_seconds_bucket{model=~\"$model\", operation=~\"$operation\"}[$__rate_interval])) by(le)) * 1000",
          "refId": "P99",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 6,
      "title": "Query Latency by Model",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "targets": [
        {
          "expr": "(sum by(model)(rate(coding_analytics_prisma_query_duration_seconds_sum{model=~\"$model\", operation=~\"$operation\"}[$__rate_interval])) / clamp_min(sum by(model)(rate(coding_analytics_prisma_query_duration_seconds_count{model=~\"$model\", operation=~\"$operation\"}[$__rate_interval])), 1)) * 1000",
          "refId": "A",
          "legendFormat": "{{model}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 7,
      "title": "Query Latency by Operation",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "targets": [
        {
          "expr": "(sum by(operation)(rate(coding_analytics_prisma_query_duration_seconds_sum{model=~\"$model\", operation=~\"$operation\"}[$__rate_interval])) / clamp_min(sum by(operation)(rate(coding_analytics_prisma_query_duration_seconds_count{model=~\"$model\", operation=~\"$operation\"}[$__rate_interval])), 1)) * 1000",
          "refId": "A",
          "legendFormat": "{{operation}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 15,
      "title": "Slow Query Trend",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 30 },
      "targets": [
        {
          "expr": "sum(rate(coding_analytics_prisma_slow_queries_total{model=~\"$model\", operation=~\"$operation\"}[$__rate_interval]))",
          "refId": "A",
          "legendFormat": "Slow Queries"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 8,
      "title": "Top Queried Models",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 30 },
      "targets": [
        {
          "expr": "topk(10, sum by(model)(rate(coding_analytics_prisma_queries_total{model=~\"$model\", operation=~\"$operation\"}[$__rate_interval])))",
          "refId": "A",
          "legendFormat": "{{model}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "options": { "orientation": "horizontal" }
    },
    {
      "id": 9,
      "title": "Slow Queries by Model",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 30 },
      "targets": [
        {
          "expr": "sum by(model)(rate(coding_analytics_prisma_slow_queries_total{model=~\"$model\", operation=~\"$operation\"}[$__rate_interval]))",
          "refId": "A",
          "legendFormat": "{{model}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "orientation": "horizontal" }
    },
    {
      "id": 10,
      "title": "Errors by Operation",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 38 },
      "targets": [
        {
          "expr": "sum by(operation)(rate(coding_analytics_prisma_errors_total{model=~\"$model\", operation=~\"$operation\"}[$__rate_interval]))",
          "refId": "A",
          "legendFormat": "{{operation}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "orientation": "horizontal" }
    },
    {
      "id": 11,
      "title": "Errors by Model",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 38 },
      "targets": [
        {
          "expr": "sum by(model)(rate(coding_analytics_prisma_errors_total{model=~\"$model\", operation=~\"$operation\"}[$__rate_interval]))",
          "refId": "A",
          "legendFormat": "{{model}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "orientation": "horizontal" }
    }
  ]
}
